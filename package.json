{
  "name": "is-not-null-or-undefined",
  "version": "1.0.2",
  "private": false,
  "description": "TypeScript predicates and type guards for nullish values, booleans, non-empty values, and renderable React nodes",
  "keywords": [
    "array-length",
    "boolean-guard",
    "empty-string",
    "non-empty",
    "not-null",
    "not-undefined",
    "null-check",
    "nullish",
    "react-node",
    "type-guard",
    "typescript",
    "undefined-check",
    "utility"
  ],
  "homepage": "https://github.com/mkaradeniz/is-not-null-or-undefined#readme",
  "bugs": {
    "url": "https://github.com/mkaradeniz/is-not-null-or-undefined/issues"
  },
  "license": "MIT",
  "author": "Max Karadeniz <max.karadeniz@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mkaradeniz/is-not-null-or-undefined.git"
  },
  "files": [
    "dist",
    "skills"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./react": {
      "types": "./dist/react.d.mts",
      "import": "./dist/react.mjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "build:watch": "tsdown --watch",
    "clean": "rimraf dist node_modules",
    "changeset": "changeset",
    "changeset:status": "changeset status --verbose",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "lint": "oxlint . --deny-warnings",
    "lint:fix": "oxlint . --fix --deny-warnings",
    "pack:dry-run": "npm pack --dry-run --ignore-scripts --json",
    "prepare": "husky",
    "prepublishOnly": "pnpm run build",
    "release": "pnpm run verify && changeset publish",
    "test": "pnpm run test:types && pnpm run lint && pnpm run test:units",
    "test:package": "pnpm run build && node scripts/test-package.mjs",
    "test:types": "tsc --project tsconfig.json --pretty --noEmit",
    "test:units": "vitest run --coverage",
    "test:units:basic": "SHOULD_REPORT_BASIC=true vitest run",
    "test:units:watch": "vitest --watch",
    "verify": "pnpm run format:check && pnpm run test && pnpm run test:package && pnpm run pack:dry-run",
    "version-packages": "changeset version && pnpm run format"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@types/node": "^22.19.19",
    "@types/react": "^19.2.14",
    "@vitest/coverage-v8": "^4.1.6",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.4",
    "oxfmt": "^0.50.0",
    "oxlint": "^1.65.0",
    "rimraf": "^6.1.3",
    "tsdown": "^0.22.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  },
  "peerDependencies": {
    "@types/react": "*"
  },
  "peerDependenciesMeta": {
    "@types/react": {
      "optional": true
    }
  },
  "lint-staged": {
    "**/*.{json,js,mjs,cjs,ts,tsx,md,yml,yaml}": "oxfmt",
    "**/*.{js,mjs,cjs,ts,tsx}": "oxlint --fix --deny-warnings"
  },
  "engines": {
    "node": ">=22.14.0",
    "pnpm": ">=10.29.2"
  },
  "packageManager": "pnpm@10.29.2"
}
